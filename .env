# =============================================================================
# spark-dev Environment Configuration
# =============================================================================

# ── Spark Connect ────────────────────────────────────────────────────────────
SPARK_REMOTE=sc://localhost:15002
SPARK_CONF_DIR=./conf

# ── Spark resource profile (container/server level — needs `make up*` + restart) ──
# `make up` uses these defaults (tuned). `make up-constrained` overrides them to
# 2g / 1g / 2 cores for OOM & spill modules. Session-level safety nets (AQE,
# broadcast threshold, shuffle partitions) are toggled per-notebook via
# common.profiles.apply_profile() — see common/README.md.
SPARK_MEM_LIMIT=3g          # Docker mem_limit on the spark-connect container
SPARK_DRIVER_MEMORY=2g      # Spark driver heap (= executor heap in local mode)
SPARK_CORES=*               # local[*] = all cores; constrained profile uses 2

# ── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:29092

# ── Ports ────────────────────────────────────────────────────────────────────
SPARK_CONNECT_PORT=15002
SPARK_THRIFT_PORT=10000
SPARK_UI_PORT=4040
SPARK_HISTORY_PORT=18080
JUPYTER_PORT=8888
KAFKA_UI_PORT=8080
KAFKA_EXTERNAL_PORT=29092

# ── dbt ──────────────────────────────────────────────────────────────────────
# Connection config used by profiles.yml via env_var()
DBT_SPARK_HOST=localhost
DBT_SPARK_PORT=10000

# ── Jupyter ──────────────────────────────────────────────────────────────────
JUPYTER_TOKEN=
PYTHONPATH=.
